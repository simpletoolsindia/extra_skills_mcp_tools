use_default_settings: true
general:
  instance_name: "MCP Server Search"
  privacypolicy_url: false
  donation_url: false
  contact_url: false
  enable_metrics: false

search:
  safe_search: 0
  autocomplete: "google"
  default_lang: "en"
  formats:
    - html
    - json

server:
  secret_key: "change-this-to-a-random-string-in-production"
  limiter: false
  public_instance: true
  bind:
    - 0.0.0.0:8080
  base_url: "https://search.sridharhomelab.in"
  limiter:
    - 0.0.0.0:8080

outgoing:
  request_timeout: 10.0
  max_request_timeout: 30.0
  user_agent: "MCP-Server/1.0 (Agentic AI Search)"
  pool_connections: 100
  pool_maxsize: 20

engines:
  - name: google
    engine: google
    shortcut: g
  - name: duckduckgo
    engine: duckduckgo
    shortcut: d
  - name: bing
    engine: bing
    shortcut: b
  - name: wikipedia
    engine: wikipedia
    shortcut: w
  - name: github
    engine: github
    shortcut: gh
  - name: youtube
    engine: youtube
    shortcut: yt
  - name: google images
    engine: google_images
    shortcut: gi
  - name: reddit
    engine: reddit
    shortcut: rd
  - name: arxiv
    engine: arxiv
    shortcut: ax
  - name: stackoverflow
    engine: stackoverflow
    shortcut: so

ui:
  static_use_hash_as_avatar_url: false
  default_theme: simple
  results_on_new_tab: false